terraform {
  required_version = ">= 1.6"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.21"
    }
    archive = {
      source  = "hashicorp/archive"
      version = "~> 2.4"
    }
    null = {
      source  = "hashicorp/null"
      version = "~> 3.2"
    }
    time = {
      source  = "hashicorp/time"
      version = "~> 0.12"
    }
  }
}

provider "aws" {
  region = var.region

  default_tags {
    tags = {
      Project   = "AgentCore"
      Pattern   = "sandbox-single-runtime"
      ManagedBy = "Terraform"
      Env       = var.environment
    }
  }
}
